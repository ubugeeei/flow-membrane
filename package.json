{
  "name": "flow-membrane",
  "version": "0.1.0",
  "description": "Experimental Flow typed routing/RSC boundary library for React 19, built around an explicit route manifest, guards, navigation, and form action boundaries.",
  "packageManager": "yarn@4.14.1",
  "main": "./dist/FlowMembrane.js",
  "module": "./dist/FlowMembrane.mjs",
  "exports": {
    ".": {
      "react-server": "./dist/Server.mjs",
      "import": "./dist/FlowMembrane.mjs",
      "require": "./dist/FlowMembrane.js",
      "default": "./dist/FlowMembrane.mjs"
    },
    "./client": {
      "import": "./dist/Client.mjs",
      "require": "./dist/Client.js",
      "default": "./dist/Client.mjs"
    },
    "./server": {
      "import": "./dist/Server.mjs",
      "require": "./dist/Server.js",
      "default": "./dist/Server.mjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node Build.js",
    "flow": "flow check",
    "prepare": "node Build.js",
    "smoke": "node Smoke.js",
    "test": "node Test.js",
    "verify": "yarn flow && yarn test && yarn build && yarn smoke"
  },
  "keywords": [
    "flow",
    "react",
    "router",
    "rsc",
    "manifest",
    "ppr",
    "navigation",
    "guard",
    "middleware"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ubugeeei/flow-membrane.git"
  },
  "bugs": {
    "url": "https://github.com/ubugeeei/flow-membrane/issues"
  },
  "homepage": "https://github.com/ubugeeei/flow-membrane#readme",
  "engines": {
    "node": ">=22.14.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=19.0.0"
  },
  "dependencies": {
    "flow-cell": "^0.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@babel/preset-flow": "^7.27.1",
    "babel-plugin-syntax-hermes-parser": "^0.36.1",
    "flow-bin": "^0.314.0",
    "happy-dom": "^20.9.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
